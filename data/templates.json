      "html_template": "<!DOCTYPE html>\n<html lang=\"sd\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>مهيني جا بهترين شاگرد - GBHSS نئون ديرو</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800;14..32,900&amp;family=Playfair+Display:wght@500;600&amp;display=swap\" rel=\"stylesheet\">\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Naskh+Arabic:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\">\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    background: #cecece;\n    display: flex; justify-content: center; align-items: flex-start;\n    padding: 20px; font-family: 'Noto Naskh Arabic', serif; direction: rtl;\n  }\n  .fb-post-wrapper {\n    width: 1080px; height: 1350px; background: #ffffff; overflow: visible;\n    box-shadow: 0 10px 50px rgba(0,0,0,0.32); border: 2px solid #b8b8b8;\n    display: flex; flex-direction: column; direction: rtl;\n  }\n\n\n  /* ===== HEADER ===== */\n  .header-top-space {\n    width: 100%; height: 28px; background: #ffffff;\n    position: relative; z-index: 5; flex-shrink: 0;\n  }\n  .header-container {\n    width: 100%; flex-shrink: 0;\n    background: linear-gradient(135deg, #083d22 0%, #08a451 45%, #0aad56 55%, #083d22 100%);\n    position: relative; overflow: visible; z-index: 10;\n  }\n  .header-container::after {\n    content: ''; position: absolute; inset: 0;\n    background: radial-gradient(ellipse at 20% 50%, rgba(252,202,19,0.10) 0%, transparent 55%);\n    pointer-events: none; z-index: 1;\n  }\n  .header-stripe { width: 100%; height: 9px; display: flex; position: relative; z-index: 0; }\n  .header-stripe span { flex: 1; }\n  .header-stripe span:nth-child(1) { background: #fcca13; }\n  .header-stripe span:nth-child(2) { background: #08a451; }\n  .header-stripe span:nth-child(3) { background: #eb1f25; }\n  .header-stripe span:nth-child(4) { background: #703336; }\n  .header-inner {\n    display: flex; align-items: center; justify-content: center;\n    padding: 14px 44px 10px; gap: 28px;\n    position: relative; z-index: 2;\n    flex-direction: row; direction: ltr;\n  }\n  .header-logo {\n    flex-shrink: 0; width: 165px; height: 165px; border-radius: 50%;\n    background: transparent; border: none;\n    display: flex; align-items: center; justify-content: center;\n    position: relative; z-index: 20;\n    margin-top: -45px; margin-bottom: -45px;\n    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.40))\n            drop-shadow(0 2px 8px rgba(0,0,0,0.24));\n  }\n  .header-logo img { width: 100%; height: 100%; object-fit: contain; display: block; }\n  .header-text { flex: 1; text-align: center; direction: rtl; }\n  .school-name-main {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 34px; font-weight: 700; color: #ffffff;\n    line-height: 1.55; text-shadow: 0 2px 10px rgba(0,0,0,0.36);\n  }\n  .school-tagline {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 15px; color: rgba(252,202,19,0.90); margin-top: 5px;\n  }\n  .header-bottom-stripe { width: 100%; height: 5px; display: flex; position: relative; z-index: 0; }\n  .header-bottom-stripe span { flex: 1; }\n  .header-bottom-stripe span:nth-child(1) { background: #703336; }\n  .header-bottom-stripe span:nth-child(2) { background: #eb1f25; }\n  .header-bottom-stripe span:nth-child(3) { background: #08a451; }\n  .header-bottom-stripe span:nth-child(4) { background: #fcca13; }\n\n\n  /* ===== BANNER ===== */\n  .page-banner {\n    width: 100%; flex-shrink: 0; padding: 14px 44px;\n    display: flex; align-items: center; justify-content: center; gap: 14px;\n    position: relative; z-index: 5;\n  }\n  .page-banner.toppers {\n    background: linear-gradient(135deg, #8a6200 0%, #c8900a 35%, #daa520 50%, #c8900a 65%, #8a6200 100%);\n  }\n  .page-banner-line { flex: 1; height: 2px; background: rgba(255,255,255,0.35); border-radius: 2px; }\n  .page-banner-icon { font-size: 24px; color: #fff7dc; flex-shrink: 0; }\n  .page-banner-title {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 26px; font-weight: 700; color: #ffffff;\n    text-shadow: 0 1px 4px rgba(0,0,0,0.25);\n  }\n\n\n  /* ===== BODY ===== */\n  .body-container {\n    flex: 1; padding: 16px 46px;\n    display: flex; flex-direction: column; overflow: hidden;\n  }\n  .body-card {\n    flex: 1;\n    background: linear-gradient(160deg, #fffef5 0%, #f9fafc 100%);\n    border: 1.5px solid #e8dec0; border-radius: 14px;\n    padding: 16px 28px 14px;\n    display: flex; flex-direction: column; overflow: hidden;\n  }\n\n\n  /* META ROW */\n  .meta-row {\n    display: flex; justify-content: center; align-items: stretch;\n    gap: 10px; margin-bottom: 10px;\n    direction: ltr;\n  }\n  .meta-chip {\n    background: #ffffff; border: 1.5px solid #e5e9ee;\n    border-radius: 10px; padding: 6px 16px;\n    display: flex; flex-direction: row; align-items: center; gap: 10px;\n    direction: rtl;\n  }\n  .meta-icon {\n    width: 32px; height: 32px; border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 13px; color: #fff; flex-shrink: 0;\n  }\n  .meta-icon.teacher { background: linear-gradient(135deg, #08a451, #066e36); }\n  .meta-icon.subject { background: linear-gradient(135deg, #703336, #8a4245); }\n  .meta-icon.month   { background: linear-gradient(135deg, #2596be, #1a7a9e); }\n  .meta-icon.cls     { background: linear-gradient(135deg, #b8860b, #d4a800); }\n  .meta-icon.marks   { background: linear-gradient(135deg, #eb1f25, #b8161c); }\n  .meta-chip-text { text-align: right; }\n  .meta-chip-label {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 11px; font-weight: 600; color: #9ca3af;\n  }\n  .meta-chip-val {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 15px; font-weight: 700; color: #111827; margin-top: 1px;\n  }\n\n\n  /* CONGRATULATIONS BANNER */\n  .congrats-banner {\n    background: linear-gradient(135deg, #083d22 0%, #08a451 50%, #083d22 100%);\n    border-radius: 12px; padding: 11px 24px;\n    text-align: center; margin-bottom: 12px;\n    position: relative; overflow: hidden;\n  }\n  .congrats-banner::after {\n    content: ''; position: absolute; inset: 0;\n    background: radial-gradient(ellipse at 50% 50%, rgba(252,202,19,0.15) 0%, transparent 70%);\n    pointer-events: none;\n  }\n  .congrats-banner-stars {\n    font-size: 16px; color: #fcca13; letter-spacing: 10px;\n    margin-bottom: 3px; position: relative; z-index: 2;\n  }\n  .congrats-banner-text {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 20px; font-weight: 700; color: #ffffff;\n    position: relative; z-index: 2;\n    text-shadow: 0 1px 4px rgba(0,0,0,0.3);\n  }\n  .congrats-banner-sub {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 13px; font-weight: 500;\n    color: rgba(252,202,19,0.90); margin-top: 2px;\n    position: relative; z-index: 2;\n  }\n\n\n  /* PODIUM ROW */\n  .podium-row {\n    display: flex; align-items: flex-end; justify-content: center;\n    gap: 20px; margin-bottom: 14px; flex-shrink: 0;\n  }\n  .topper-card {\n    display: flex; flex-direction: column; align-items: center; position: relative;\n  }\n  .topper-card.pos-1 { order: 2; }\n  .topper-card.pos-2 { order: 1; }\n  .topper-card.pos-3 { order: 3; }\n\n\n  .rank-badge {\n    position: absolute; top: -10px; left: -6px; z-index: 5;\n    width: 42px; height: 42px; border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 900; color: #fff;\n    border: 3px solid #fff; box-shadow: 0 3px 10px rgba(0,0,0,0.28);\n  }\n  .topper-card.pos-1 .rank-badge {\n    background: linear-gradient(135deg, #FFD700, #FFA500);\n    width: 50px; height: 50px; font-size: 17px; top: -14px; left: -8px;\n  }\n  .topper-card.pos-2 .rank-badge { background: linear-gradient(135deg, #B0B0B0, #909090); }\n  .topper-card.pos-3 .rank-badge { background: linear-gradient(135deg, #CD7F32, #a0622a); }\n\n\n  .crown-icon {\n    position: absolute; top: -28px; left: 50%; transform: translateX(-50%);\n    font-size: 30px; color: #FFD700; z-index: 6;\n    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.28));\n  }\n\n\n  .topper-photo {\n    border-radius: 50%; overflow: hidden;\n    display: flex; align-items: center; justify-content: center;\n    position: relative; margin-bottom: 10px; flex-shrink: 0;\n  }\n  .topper-card.pos-1 .topper-photo {\n    width: 178px; height: 178px; border: 6px solid #FFD700;\n    box-shadow: 0 0 0 4px rgba(255,215,0,0.22), 0 8px 24px rgba(0,0,0,0.18);\n  }\n  .topper-card.pos-2 .topper-photo,\n  .topper-card.pos-3 .topper-photo {\n    width: 148px; height: 148px; border: 5px solid #B0B0B0;\n    box-shadow: 0 0 0 3px rgba(176,176,176,0.20), 0 6px 16px rgba(0,0,0,0.14);\n  }\n  .topper-card.pos-3 .topper-photo { border-color: #CD7F32; }\n  .topper-photo img {\n    width: 100%; height: 100%; object-fit: cover; object-position: top center; border-radius: 50%;\n  }\n  .topper-name {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 18px; font-weight: 700; color: #111827;\n    text-align: center; margin-bottom: 2px;\n  }\n  .topper-card.pos-1 .topper-name { font-size: 21px; }\n  .topper-class {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 13px; color: #08a451; text-align: center; margin-bottom: 6px;\n  }\n  .tmc {\n    background: #fff; border: 1.5px solid #e5e8ec;\n    border-radius: 8px; padding: 5px 16px; text-align: center;\n  }\n  .tmc-label {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 10px; font-weight: 600; color: #9ca3af;\n  }\n  .tmc-val { font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 800; }\n  .topper-card.pos-1 .tmc-val { color: #b8860b; }\n  .topper-card.pos-2 .tmc-val { color: #707070; }\n  .topper-card.pos-3 .tmc-val { color: #CD7F32; }\n\n\n  /* MENTIONS TITLE */\n  .mentions-title {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 15px; font-weight: 700; color: #703336;\n    text-align: center; margin-bottom: 10px;\n  }\n  .mentions-title::before, .mentions-title::after {\n    content: ''; display: inline-block; width: 80px; height: 1px;\n    background: #dde2e8; vertical-align: middle; margin: 0 10px;\n  }\n\n\n  /* MENTIONS GRID */\n  .mentions-grid {\n    display: grid; grid-template-columns: 1fr 1fr;\n    gap: 10px; flex: 1;\n  }\n\n\n  .mention-row {\n    display: flex; align-items: center; gap: 0;\n    border-radius: 14px; overflow: hidden;\n    position: relative;\n    border: 2.5px solid transparent;\n    background-clip: padding-box;\n  }\n  .mention-row:nth-child(1) { border-color: #FFD700; box-shadow: 0 3px 12px rgba(255,215,0,0.20); }\n  .mention-row:nth-child(2) { border-color: #08a451; box-shadow: 0 3px 12px rgba(8,164,81,0.18); }\n  .mention-row:nth-child(3) { border-color: #eb1f25; box-shadow: 0 3px 12px rgba(235,31,37,0.15); }\n  .mention-row:nth-child(4) { border-color: #2596be; box-shadow: 0 3px 12px rgba(37,150,190,0.18); }\n\n\n  .mention-row::before {\n    content: ''; position: absolute;\n    right: 0; top: 0; width: 5px; height: 100%;\n    border-radius: 0 12px 12px 0;\n  }\n  .mention-row:nth-child(1)::before { background: #FFD700; }\n  .mention-row:nth-child(2)::before { background: #08a451; }\n  .mention-row:nth-child(3)::before { background: #eb1f25; }\n  .mention-row:nth-child(4)::before { background: #2596be; }\n\n\n  .mention-inner {\n    display: flex; align-items: center; gap: 10px;\n    background: #ffffff; width: 100%;\n    padding: 10px 14px 10px 10px;\n    flex-direction: row-reverse;\n  }\n\n\n  .mention-rank {\n    width: 34px; height: 34px; border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    font-family: 'Inter', sans-serif;\n    font-size: 14px; font-weight: 800; color: #fff; flex-shrink: 0;\n  }\n  .mention-row:nth-child(1) .mention-rank { background: linear-gradient(135deg, #d4a800, #FFD700); }\n  .mention-row:nth-child(2) .mention-rank { background: linear-gradient(135deg, #08a451, #066e36); }\n  .mention-row:nth-child(3) .mention-rank { background: linear-gradient(135deg, #eb1f25, #b8161c); }\n  .mention-row:nth-child(4) .mention-rank { background: linear-gradient(135deg, #2596be, #1a7a9e); }\n\n\n  .mention-photo {\n    width: 88px; height: 88px;\n    border-radius: 50%; overflow: hidden;\n    flex-shrink: 0;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.13);\n  }\n  .mention-row:nth-child(1) .mention-photo { border: 3px solid #FFD700; }\n  .mention-row:nth-child(2) .mention-photo { border: 3px solid #08a451; }\n  .mention-row:nth-child(3) .mention-photo { border: 3px solid #eb1f25; }\n  .mention-row:nth-child(4) .mention-photo { border: 3px solid #2596be; }\n  .mention-photo img {\n    width: 100%; height: 100%; object-fit: cover; object-position: top center; border-radius: 50%;\n  }\n\n\n  .mention-info { flex: 1; text-align: right; padding-right: 4px; }\n  .mention-name {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 18px; font-weight: 700; color: #111827;\n    line-height: 1.3;\n  }\n  .mention-class {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 12px; color: #08a451; margin-top: 1px;\n  }\n\n\n  .mention-marks {\n    font-family: 'Inter', sans-serif;\n    font-size: 20px; font-weight: 900; text-align: left; flex-shrink: 0; line-height: 1;\n  }\n  .mention-row:nth-child(1) .mention-marks { color: #b8860b; }\n  .mention-row:nth-child(2) .mention-marks { color: #08a451; }\n  .mention-row:nth-child(3) .mention-marks { color: #eb1f25; }\n  .mention-row:nth-child(4) .mention-marks { color: #2596be; }\n  .mention-marks span { font-size: 12px; font-weight: 500; color: #9ca3af; }\n\n\n  /* QUOTE */\n  .topper-quote {\n    margin-top: 10px; padding-top: 10px;\n    border-top: 1px solid #e5e9ee; text-align: center;\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 16px; color: #9ca3af; font-style: italic;\n  }\n  .topper-quote i { color: #fcca13; margin: 0 5px; }\n\n\n  /* ===== FOOTER ===== */\n  .footer-container { width: 100%; flex-shrink: 0; }\n  .footer-inner {\n    background: linear-gradient(135deg, #083d22 0%, #08a451 50%, #083d22 100%);\n    padding: 16px 44px 14px; position: relative; overflow: hidden;\n  }\n  .footer-inner::after {\n    content: ''; position: absolute; inset: 0;\n    background: radial-gradient(ellipse at 20% 50%, rgba(252,202,19,0.07) 0%, transparent 55%);\n    pointer-events: none;\n  }\n  .footer-row {\n    display: flex; align-items: center; justify-content: space-between;\n    gap: 12px; position: relative; z-index: 2;\n  }\n  .footer-school-name {\n    font-family: 'Noto Naskh Arabic', serif;\n    font-size: 13px; font-weight: 700;\n    color: rgba(255,255,255,0.92); white-space: nowrap; flex-shrink: 0;\n  }\n  .footer-divider { width: 1px; height: 36px; background: rgba(255,255,255,0.22); flex-shrink: 0; }\n  .footer-contact { display: flex; align-items: center; gap: 18px; flex: 1; justify-content: center; }\n  .footer-contact-item {\n    display: flex; align-items: center; gap: 6px;\n    color: rgba(255,255,255,0.84); white-space: nowrap; flex-direction: row-reverse;\n  }\n  .footer-contact-item i { color: #fcca13; font-size: 12px; flex-shrink: 0; }\n  .footer-contact-item span { font-family: 'Noto Naskh Arabic', serif; font-size: 12px; }\n  .footer-contact-item .latin {\n    font-family: 'Inter', sans-serif; font-size: 11.5px; direction: ltr; unicode-bidi: embed;\n  }\n  .footer-social { display: flex; gap: 9px; flex-shrink: 0; }\n  .footer-social a {\n    width: 36px; height: 36px; border-radius: 50%;\n    background: rgba(255,255,255,0.13); border: 1px solid rgba(255,255,255,0.20);\n    display: flex; align-items: center; justify-content: center;\n    color: #ffffff; font-size: 14px; text-decoration: none;\n  }\n  .footer-stripe { width: 100%; height: 7px; display: flex; }\n  .footer-stripe span { flex: 1; }\n  .footer-stripe span:nth-child(1) { background: #fcca13; }\n  .footer-stripe span:nth-child(2) { background: #08a451; }\n  .footer-stripe span:nth-child(3) { background: #eb1f25; }\n  .footer-stripe span:nth-child(4) { background: #703336; }\n</style>\n</head>\n<body>\n<div class=\"fb-post-wrapper\">\n\n\n  <div class=\"header-top-space\"></div>\n  <div class=\"header-container\">\n    <div class=\"header-stripe\"><span></span><span></span><span></span><span></span></div>\n    <div class=\"header-inner\">\n      <div class=\"header-text\">\n        <div class=\"school-name-main\">گورنمينٽ بوائز هائير سيڪنڊري اسڪول نئون ديرو</div>\n        <div class=\"school-tagline\">تعليم ۾ بهترين — ضلعو لاڙڪاڻو، سنڌ</div>\n      </div>\n      <div class=\"header-logo\">\n        <img src=\"https://uploads.onecompiler.io/44hsxfpta/44hsy3ayz/1002193711.png\" alt=\"GBHSS Logo\">\n      </div>\n    </div>\n    <div class=\"header-bottom-stripe\"><span></span><span></span><span></span><span></span></div>\n  </div>\n\n\n  <div class=\"page-banner toppers\">\n    <div class=\"page-banner-line\"></div>\n    <div class=\"page-banner-icon\"><i class=\"fas fa-trophy\"></i></div>\n    <div class=\"page-banner-title\">مهيني جا بهترين شاگرد</div>\n    <div class=\"page-banner-line\"></div>\n  </div>\n\n\n  <div class=\"body-container\">\n    <div class=\"body-card\">\n\n\n      <!-- META ROW: Teacher + Subject + Month + Class + Total Marks -->\n      <div class=\"meta-row\">\n        <div class=\"meta-chip\">\n          <div class=\"meta-icon teacher\"><i class=\"fas fa-chalkboard-teacher\"></i></div>\n          <div class=\"meta-chip-text\">\n            <div class=\"meta-chip-label\">استاد</div>\n            <div class=\"meta-chip-val\">{{teacher_name}}</div>\n          </div>\n        </div>\n        <div class=\"meta-chip\">\n          <div class=\"meta-icon subject\"><i class=\"fas fa-book-open\"></i></div>\n          <div class=\"meta-chip-text\">\n            <div class=\"meta-chip-label\">مضمون</div>\n            <div class=\"meta-chip-val\">{{subject}}</div>\n          </div>\n        </div>\n        <div class=\"meta-chip\">\n          <div class=\"meta-icon month\"><i class=\"fas fa-calendar-alt\"></i></div>\n          <div class=\"meta-chip-text\">\n            <div class=\"meta-chip-label\">مهينو</div>\n            <div class=\"meta-chip-val\">{{month_year}}</div>\n          </div>\n        </div>\n        <div class=\"meta-chip\">\n          <div class=\"meta-icon cls\"><i class=\"fas fa-users\"></i></div>\n          <div class=\"meta-chip-text\">\n            <div class=\"meta-chip-label\">جماعت</div>\n            <div class=\"meta-chip-val\">{{class_grade}}</div>\n          </div>\n        </div>\n        <div class=\"meta-chip\">\n          <div class=\"meta-icon marks\"><i class=\"fas fa-star-half-alt\"></i></div>\n          <div class=\"meta-chip-text\">\n            <div class=\"meta-chip-label\">ڪل نمبر</div>\n            <div class=\"meta-chip-val\">{{total_marks}}</div>\n          </div>\n        </div>\n      </div>\n\n\n      <!-- CONGRATULATIONS BANNER -->\n      <div class=\"congrats-banner\">\n        <div class=\"congrats-banner-stars\">★ ★ ★ ★ ★</div>\n        <div class=\"congrats-banner-text\">مبارڪباد — بهترين شاگردن کي دلي مبارڪباد</div>\n        <div class=\"congrats-banner-sub\">توهان جي محنت ۽ لگن تي اسڪول کي فخر آهي</div>\n      </div>\n\n\n      <!-- PODIUM -->\n      <div class=\"podium-row\">\n\n\n        <!-- 2nd Place -->\n        <div class=\"topper-card pos-2\">\n          <div class=\"rank-badge\">2</div>\n          <div class=\"topper-photo\">\n            <img src=\"{{student_2_photo}}\" alt=\"ٻيو نمبر\">\n          </div>\n          <div class=\"topper-name\">{{student_2_name}}</div>\n          <div class=\"topper-class\">{{student_2_class}}</div>\n          <div class=\"tmc\"><div class=\"tmc-label\">نمبر</div><div class=\"tmc-val\">{{student_2_marks}}/{{total_marks}}</div></div>\n        </div>\n\n\n        <!-- 1st Place -->\n        <div class=\"topper-card pos-1\">\n          <div class=\"rank-badge\">1</div>\n          <div style=\"position:relative;\">\n            <div class=\"crown-icon\"><i class=\"fas fa-crown\"></i></div>\n            <div class=\"topper-photo\">\n              <img src=\"{{student_1_photo}}\" alt=\"پهريون نمبر\">\n            </div>\n          </div>\n          <div class=\"topper-name\">{{student_1_name}}</div>\n          <div class=\"topper-class\">{{student_1_class}}</div>\n          <div class=\"tmc\"><div class=\"tmc-label\">نمبر</div><div class=\"tmc-val\">{{student_1_marks}}/{{total_marks}}</div></div>\n        </div>\n\n\n        <!-- 3rd Place -->\n        <div class=\"topper-card pos-3\">\n          <div class=\"rank-badge\">3</div>\n          <div class=\"topper-photo\">\n            <img src=\"{{student_3_photo}}\" alt=\"ٽيون نمبر\">\n          </div>\n          <div class=\"topper-name\">{{student_3_name}}</div>\n          <div class=\"topper-class\">{{student_3_class}}</div>\n          <div class=\"tmc\"><div class=\"tmc-label\">نمبر</div><div class=\"tmc-val\">{{student_3_marks}}/{{total_marks}}</div></div>\n        </div>\n\n\n      </div>\n\n\n      <!-- MENTIONS TITLE -->\n      <div class=\"mentions-title\">قابل تعريف شاگرد</div>\n\n\n      <!-- MENTIONS GRID -->\n      <div class=\"mentions-grid\">\n\n\n        <!-- 4th -->\n        <div class=\"mention-row\">\n          <div class=\"mention-inner\">\n            <div class=\"mention-rank\">4</div>\n            <div class=\"mention-photo\">\n              <img src=\"{{student_4_photo}}\" alt=\"چوٿون نمبر\">\n            </div>\n            <div class=\"mention-info\">\n              <div class=\"mention-name\">{{student_4_name}}</div>\n              <div class=\"mention-class\">{{student_4_class}}</div>\n            </div>\n            <div class=\"mention-marks\">{{student_4_marks}}<span>/{{total_marks}}</span></div>\n          </div>\n        </div>\n\n\n        <!-- 5th -->\n        <div class=\"mention-row\">\n          <div class=\"mention-inner\">\n            <div class=\"mention-rank\">5</div>\n            <div class=\"mention-photo\">\n              <img src=\"{{student_5_photo}}\" alt=\"پنجون نمبر\">\n            </div>\n            <div class=\"mention-info\">\n              <div class=\"mention-name\">{{student_5_name}}</div>\n              <div class=\"mention-class\">{{student_5_class}}</div>\n            </div>\n            <div class=\"mention-marks\">{{student_5_marks}}<span>/{{total_marks}}</span></div>\n          </div>\n        </div>\n\n\n        <!-- 6th -->\n        <div class=\"mention-row\">\n          <div class=\"mention-inner\">\n            <div class=\"mention-rank\">6</div>\n            <div class=\"mention-photo\">\n              <img src=\"{{student_6_photo}}\" alt=\"ڇهون نمبر\">\n            </div>\n            <div class=\"mention-info\">\n              <div class=\"mention-name\">{{student_6_name}}</div>\n              <div class=\"mention-class\">{{student_6_class}}</div>\n            </div>\n            <div class=\"mention-marks\">{{student_6_marks}}<span>/{{total_marks}}</span></div>\n          </div>\n        </div>\n\n\n        <!-- 7th -->\n        <div class=\"mention-row\">\n          <div class=\"mention-inner\">\n            <div class=\"mention-rank\">7</div>\n            <div class=\"mention-photo\">\n              <img src=\"{{student_7_photo}}\" alt=\"ستون نمبر\">\n            </div>\n            <div class=\"mention-info\">\n              <div class=\"mention-name\">{{student_7_name}}</div>\n              <div class=\"mention-class\">{{student_7_class}}</div>\n            </div>\n            <div class=\"mention-marks\">{{student_7_marks}}<span>/{{total_marks}}</span></div>\n          </div>\n        </div>\n\n\n      </div>\n\n\n      <!-- QUOTE -->\n      <div class=\"topper-quote\">\n        <i class=\"fas fa-quote-right\"></i>\n        {{quote}}\n        <i class=\"fas fa-quote-left\"></i>\n      </div>\n\n\n    </div>\n  </div>\n\n\n  <!-- FOOTER -->\n  <div class=\"footer-container\">\n    <div class=\"footer-inner\">\n      <div class=\"footer-row\">\n        <div class=\"footer-school-name\">گورنمينٽ بوائز هائير سيڪنڊري اسڪول نئون ديرو</div>\n        <div class=\"footer-divider\"></div>\n        <div class=\"footer-contact\">\n          <div class=\"footer-contact-item\"><i class=\"fas fa-map-marker-alt\"></i><span>نئون ديرو، لاڙڪاڻو، سنڌ</span></div>\n          <div class=\"footer-contact-item\"><i class=\"fas fa-phone-alt\"></i><span class=\"latin\">+92-334-2766475</span></div>\n          <div class=\"footer-contact-item\"><i class=\"fas fa-id-card\"></i><span class=\"latin\">SEMIS# 413030370</span></div>\n        </div>\n        <div class=\"footer-divider\"></div>\n        <div class=\"footer-social\">\n          <a href=\"#\"><i class=\"fab fa-facebook-f\"></i></a>\n          <a href=\"#\"><i class=\"fab fa-youtube\"></i></a>\n          <a href=\"#\"><i class=\"fab fa-whatsapp\"></i></a>\n        </div>\n      </div>\n    </div>\n    <div class=\"footer-stripe\"><span></span><span></span><span></span><span></span></div>\n  </div>\n\n\n</div>\n</body>\n</html>"
    }
  ]
